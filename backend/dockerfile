FROM node:20-alpine

WORKDIR /app

# Install build tools needed for better-sqlite3 native bindings
RUN apk add --no-cache python3 make g++

# Install dependencies first (layer caching)
COPY package.json .
COPY .env .
RUN npm install

# Copy source
COPY server.js .


EXPOSE 4000

ENV PORT=4000

CMD ["node", "server.js"]